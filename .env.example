# ============================================================
# Local development defaults — copy to .env and adjust as needed
# ============================================================

# Payload — required
# Generate a fresh random string for production (e.g. `openssl rand -hex 32`)
PAYLOAD_SECRET=b5e19ffa2531de53ffcce734

# MongoDB connection
# Local dev:  mongodb://127.0.0.1/code-ethics-poc
# Production: paste the Atlas SRV string, e.g.
#   mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/codeethics?retryWrites=true&w=majority
DATABASE_URI=mongodb://127.0.0.1/code-ethics-poc

# Public base URL of the API for the Next.js frontend's fetch calls
# Local:      http://localhost:3000/api
# Production: https://www.codeethics.in/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Transactional email (contact form submissions)
# Get a free key at https://resend.com — leave blank locally to disable
RESEND_API_KEY=

# ============================================================
# S3 — REQUIRED IN PRODUCTION, OPTIONAL LOCALLY
# ------------------------------------------------------------
# When S3_BUCKET is set, Payload media uploads go to S3 instead
# of local disk (required on AWS Amplify / any serverless host
# because Lambda has no persistent filesystem).
# Leave all four blank in local dev to keep using local disk.
# ============================================================
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
